    android:title="@string/secret_settings_category_toolbar_title"
    app:iconSpaceReserved="false">
    <SwitchPreferenceCompat
      android:key="@string/pref_key_enable_toolbar_redesign"
      android:title="@string/preferences_debug_settings_toolbar_redesign"
      app:iconSpaceReserved="false" />
    <SwitchPreferenceCompat
      android:key="@string/pref_key_enable_toolbar_customization"
      android:title="@string/preferences_debug_settings_toolbar_customization"
      app:iconSpaceReserved="false" />
    <SwitchPreferenceCompat
      android:defaultValue="false"
      android:key="@string/pref_key_use_minimal_bottom_toolbar_while_entering_text"
      android:title="@string/preferences_debug_settings_use_minimal_bottom_toolbar_while_entering_text"
      app:iconSpaceReserved="false" />
    <SwitchPreferenceCompat
      android:defaultValue="false"
      android:key="@string/pref_key_use_scroll_data_for_dynamic_toolbar"
      android:title="@string/preferences_debug_settings_use_scroll_data_for_dynamic_toolbar"
      app:iconSpaceReserved="false" />
    <SwitchPreferenceCompat
      android:defaultValue="false"
      android:key="@string/pref_key_should_show_custom_tab_extensions"
      android:title="@string/preferences_debug_settings_custom_tab_extensions"
      app:iconSpaceReserved="false" />
