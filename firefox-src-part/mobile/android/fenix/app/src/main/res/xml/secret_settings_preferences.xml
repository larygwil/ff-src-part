      android:title="@string/preferences_debug_settings_mozilla_ads_client"
      app:iconSpaceReserved="false" />
    <SwitchPreferenceCompat
      android:key="@string/pref_key_enable_merino_client"
      android:title="@string/preferences_debug_settings_merino_client"
      app:iconSpaceReserved="false" />
